# Local overrides (gitignored). Copy to .env.local and fill in secrets.
# Loaded after .env; values here win over .env for the same key.
# Add any machine-specific or secret settings below.

# Resend (auth verification / password-reset emails)
MAIL_RESEND=true
RESEND_API_KEY=
RESEND_FROM=QTask <notify@qtask.dev>

# Public URLs for this environment
APP_URL=https://qtask.dev
CORS_ORIGIN=https://qtask.dev

# Optional local knobs (uncomment as needed):
# JWT_SECRET=
# MONGODB_URI=
# OLLAMA_BASE_URL=
# REGISTRATION_ENABLED=true
# LOG_LEVEL=debug
