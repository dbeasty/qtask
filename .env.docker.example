# Production Docker Compose environment
# Copy to .env and adjust before: docker compose --profile app up -d

PORT=3003
MONGO_PORT=

# Secrets source: env (default — secrets in this file) | vault
SECRETS_BACKEND=env
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_SECRET_PATH=secret/data/qtask/production

MONGO_ROOT_USER=qtask
MONGO_ROOT_PASSWORD=change-me-strong-password

MONGODB_URI=mongodb://qtask:change-me-strong-password@mongodb:27017/qtask?authSource=admin

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
CORS_ORIGIN=https://qtask.dev
APP_URL=https://qtask.dev
TRUST_PROXY=true

# Mail: prefer Resend. Set MAIL_RESEND=true and RESEND_API_KEY (or MAIL_SMTP=true + SMTP_*).
MAIL_RESEND=true
RESEND_API_KEY=
RESEND_FROM=QTask <notify@qtask.dev>

MAIL_SMTP=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qtask.dev

# Set to false to close new account creation (capacity / ops). Restart after changing.
REGISTRATION_ENABLED=true

# Use ollama service when --profile ollama is enabled, or a LAN Jetson host:
OLLAMA_BASE_URL=http://ollama:11434
# Jetson (native or deploy/docker-compose.jetson.yml) — use service VLAN IP:
# OLLAMA_BASE_URL=http://192.168.13.14:11434
# Prefer llama3.2:3b on Jetson Orin Nano 8GB; llama3.1 is tighter with embeddings
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Chat keep-alive (-1 = forever on Ollama); embeddings unload after each request (0), CPU by default
OLLAMA_KEEP_ALIVE=-1
OLLAMA_EMBEDDING_KEEP_ALIVE=0
OLLAMA_EMBEDDING_NUM_GPU=0
LOG_LEVEL=info

# Standalone admin app (use --profile admin; production compose binds it to loopback)
ADMIN_PORT=3004
ADMIN_AUTH_MODE=password
ADMIN_PASSWORD=change-me-to-a-strong-admin-password
# Optional: store bcrypt hash instead of plaintext (npm run hash-admin-password)
# HASH_ADMIN_PASSWORD=true
# ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=change-me-to-a-separate-long-random-string
ADMIN_PROXY_SECRET=
ADMIN_COOKIE_SECURE=true
# Require typing the user email before admin delete (default: off)
# ADMIN_DELETE_CONFIRM_EMAIL=true
LLM_METRICS_RETENTION_DAYS=30
OLLAMA_DOCKER_CONTAINER=qtask-ollama
# Jetson Compose docker-proxy on service VLAN. Same-host profile: http://docker-proxy:2375/v1.44
# OLLAMA_DOCKER_STATS_URL=http://192.168.13.14:2375/v1.44
# DCGM_METRICS_URL=   # leave unset for Jetson
