# Production Docker Compose environment
# Copy to .env and adjust before: docker compose --profile app up -d

PORT=3000
MONGO_PORT=

MONGO_ROOT_USER=qtask
MONGO_ROOT_PASSWORD=change-me-strong-password

MONGODB_URI=mongodb://qtask:change-me-strong-password@mongodb:27017/qtask?authSource=admin

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
CORS_ORIGIN=https://qtask.example.com
APP_URL=https://qtask.example.com
TRUST_PROXY=true

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LOG_LEVEL=info
