# Server
PORT=3000
NODE_ENV=development

# Secrets source: env (default) | vault (optional HashiCorp Vault)
SECRETS_BACKEND=env
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_SECRET_PATH=secret/data/qtask/production
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# MongoDB (local dev — no auth; 127.0.0.1 avoids IPv6 localhost issues with Docker on macOS)
MONGODB_URI=mongodb://127.0.0.1:27017/qtask
# Optional host-volume encryption (production standalone; default off)
MONGO_ENCRYPT_AT_REST=false

# Authentication (required in production when SECRETS_BACKEND=env)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — web client origin in development
CORS_ORIGIN=http://localhost:5173

# Public web app URL (used in verification and password-reset email links)
APP_URL=http://localhost:5173

# Production example (uncomment and adjust if deploying to qtask.dev):
# CORS_ORIGIN=https://qtask.dev
# APP_URL=https://qtask.dev

# Mail provider (optional for startup; required in production for registration/password-reset emails)
# Prefer Resend (HTTP API). Set MAIL_RESEND=true and RESEND_API_KEY.
# Or use SMTP with MAIL_SMTP=true and SMTP_* vars. If both flags are true, Resend wins.
# Backward compat: SMTP_HOST alone still enables SMTP when neither flag is set.
MAIL_RESEND=false
RESEND_API_KEY=
RESEND_FROM=noreply@qtask.dev

MAIL_SMTP=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qtask.dev

# Set to false to close new account creation (capacity / ops). Restart after changing.
REGISTRATION_ENABLED=true

# Set to true when behind a reverse proxy (Caddy/nginx)
TRUST_PROXY=false

# Serve built React client from the API in production
SERVE_CLIENT=true

# Ollama (local SLM + embeddings). For Jetson LAN / Compose, see docs/DEPLOY.md
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=-1
OLLAMA_EMBEDDING_KEEP_ALIVE=0
OLLAMA_EMBEDDING_NUM_GPU=0

# Standalone admin application (port should remain behind a firewall / loopback proxy)
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3004
ADMIN_AUTH_MODE=password
ADMIN_PASSWORD=change-me-to-a-strong-admin-password
# Optional: store bcrypt hash instead of plaintext (npm run hash-admin-password)
# HASH_ADMIN_PASSWORD=true
# ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=change-me-to-a-separate-long-random-string
# For ADMIN_AUTH_MODE=mtls, configure nginx client verification and set:
ADMIN_PROXY_SECRET=
ADMIN_COOKIE_SECURE=false
# Require typing the user email before admin delete (default: off)
# ADMIN_DELETE_CONFIRM_EMAIL=true
LLM_METRICS_RETENTION_DAYS=30
# Optional live Ollama resource collectors:
OLLAMA_DOCKER_STATS_URL=
OLLAMA_DOCKER_CONTAINER=qtask-ollama
DCGM_METRICS_URL=
# Jetson GPU stats sidecar (on-demand sysfs reader on the Jetson host):
# JETSON_GPU_STATS_URL=http://192.168.13.14:9401/gpu

# Logging (debug | info | warn | error)
LOG_LEVEL=debug

# MCP in Cursor — set to a JWT from POST /api/auth/login
# MCP_JWT=eyJ...
