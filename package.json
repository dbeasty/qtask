{
  "name": "qtask",
  "version": "0.1.18",
  "description": "AI-native, MCP-powered task management backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/agent/context.md dist/agent/",
    "start": "node dist/index.js",
    "admin": "tsx src/admin/index.ts",
    "start:admin": "node dist/admin/index.js",
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/mcp/standalone.ts",
    "dev:client": "npm run dev --prefix client",
    "dev:admin-client": "npm run dev --prefix admin-client",
    "dev:all": "concurrently -n api,web,admin,admin-web -c blue,green,magenta,cyan \"npm run dev\" \"npm run dev:client\" \"npm run admin\" \"npm run dev:admin-client\"",
    "build:all": "npm run build && npm run build --prefix client && npm run build --prefix admin-client",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "release": "bash scripts/build-release.sh",
    "release:jetson": "bash scripts/build-jetson-release.sh",
    "publish:jetson": "bash scripts/publish-jetson-release.sh",
    "release:app": "bash scripts/build-app-release.sh",
    "publish:app": "bash scripts/publish-app-release.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.16.0",
    "nodemailer": "^9.0.3",
    "resend": "^6.17.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.0",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
