# Production environment for standalone / systemd deployment
# Copy to .env in the app directory (e.g. /opt/qtask/.env)

PORT=3003
NODE_ENV=production

# MongoDB on the same host (Docker: deploy/docker-compose.mongodb.yml)
MONGODB_URI=mongodb://localhost:27017/qtask

# Authentication (required)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Public URLs (your domain — nginx proxies to port 3003)
CORS_ORIGIN=https://qtask.dev
APP_URL=https://qtask.dev
TRUST_PROXY=true

# Mail (optional for startup; required for registration/password-reset emails)
# Prefer Resend — create an API key and verify your domain at https://resend.com
MAIL_RESEND=true
RESEND_API_KEY=
RESEND_FROM=QTask <notify@qtask.dev>

# Alternative: classic SMTP (set MAIL_RESEND=false and MAIL_SMTP=true)
MAIL_SMTP=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qtask.dev

# Set to false to close new account creation (capacity / ops). Restart after changing.
REGISTRATION_ENABLED=true

SERVE_CLIENT=true
LOG_LEVEL=info

# Ollama on Jetson Nano (or another LAN host)
OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
