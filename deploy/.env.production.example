# Production environment for standalone / systemd deployment
# Copy to .env in the app directory (e.g. /opt/qtask/.env on 192.168.13.13)

PORT=3003
NODE_ENV=production

# Secrets source: env (default — secrets in this file) | vault (HashiCorp Vault)
SECRETS_BACKEND=env
# When SECRETS_BACKEND=vault, set VAULT_* and remove secrets below from this file.
# Store AppRole IDs with systemd-creds (see docs/DEPLOY.md), then uncomment LoadCredential
# in deploy/qtask.service and deploy/qtask-admin.service.
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_SECRET_PATH=secret/data/qtask/production

# MongoDB on the same host (Docker: deploy/start-mongodb.sh)
MONGODB_URI=mongodb://localhost:27017/qtask
# Optional Mongo root auth (also used by start-mongodb.sh / Compose):
# MONGO_ROOT_USER=qtask
# MONGO_ROOT_PASSWORD=change-me
# Optional LUKS encryption at rest for the data directory (default off):
MONGO_ENCRYPT_AT_REST=false
# MONGO_ENCRYPT_MOUNT=/var/lib/qtask/mongo-data

# Authentication (required when SECRETS_BACKEND=env)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Public URLs (your domain — nginx proxies to port 3003)
CORS_ORIGIN=https://qtask.dev
APP_URL=https://qtask.dev
TRUST_PROXY=true

# Mail (optional for startup; required for registration/password-reset emails)
# Prefer Resend — create an API key and verify your domain at https://resend.com
MAIL_RESEND=true
RESEND_API_KEY=
RESEND_FROM="QTask <notify@qtask.dev>"

# Alternative: classic SMTP (set MAIL_RESEND=false and MAIL_SMTP=true)
MAIL_SMTP=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qtask.dev

# Set to false to close new account creation (capacity / ops). Restart after changing.
REGISTRATION_ENABLED=true

SERVE_CLIENT=true
LOG_LEVEL=info

# Ollama on Jetson service VLAN (native or deploy/docker-compose.jetson.yml — see docs/DEPLOY.md)
OLLAMA_BASE_URL=http://192.168.13.14:11434
# Prefer llama3.2:3b on Jetson Orin Nano 8GB; llama3.1 is tighter with embeddings
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Chat pinned on Jetson; embeddings on demand (CPU, unload after request)
OLLAMA_KEEP_ALIVE=-1
OLLAMA_EMBEDDING_KEEP_ALIVE=0
OLLAMA_EMBEDDING_NUM_GPU=0

# Standalone admin app. Keep port 3004 firewalled and proxy it separately.
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3004
ADMIN_AUTH_MODE=password
ADMIN_PASSWORD=change-me-to-a-strong-admin-password
# Optional: store bcrypt hash instead of plaintext (npm run hash-admin-password)
# HASH_ADMIN_PASSWORD=true
# ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=change-me-to-a-separate-long-random-string
ADMIN_PROXY_SECRET=
ADMIN_COOKIE_SECURE=true
# Require typing the user email before admin delete (default: off)
# ADMIN_DELETE_CONFIRM_EMAIL=true
LLM_METRICS_RETENTION_DAYS=30
# Jetson Compose docker-proxy on service VLAN (CPU/RAM). Leave blank for native Ollama without proxy.
OLLAMA_DOCKER_STATS_URL=http://192.168.13.14:2375/v1.44
OLLAMA_DOCKER_CONTAINER=qtask-ollama
# DCGM is for discrete NVIDIA GPUs on the app host — leave unset for Jetson
DCGM_METRICS_URL=
