# Jetson-side notes for deploy/docker-compose.jetson.yml
# Copy jetson deploy files to /opt/qtask-ollama on the Jetson (not the app host).
#
# Model selection is configured on the APP HOST (.env), not here:
#   OLLAMA_MODEL=llama3.2:3b
#   OLLAMA_EMBEDDING_MODEL=nomic-embed-text
#
# Recommended for Jetson Orin Nano 8GB (classic Nano 4GB: use even smaller models):
#   llama3.2:3b + nomic-embed-text
# Optional heavier chat model (tight on 8GB with embeddings):
#   llama3.1
#
# After compose is up, pull models on the Jetson:
#   docker exec qtask-ollama ollama pull llama3.2:3b
#   docker exec qtask-ollama ollama pull nomic-embed-text
#
# App host should point at this Jetson (replace IP):
#   OLLAMA_BASE_URL=http://192.168.1.100:11434
#   OLLAMA_DOCKER_STATS_URL=http://192.168.1.100:2375/v1.41
#   OLLAMA_DOCKER_CONTAINER=qtask-ollama
#   # DCGM_METRICS_URL=   # leave unset — DCGM is not used on Jetson
#
# Firewall: allow LAN to ports 11434 and 2375. Do not forward them to the internet.
# GPU: requires NVIDIA Container Toolkit. For CPU-only, edit docker-compose.jetson.yml
# and remove `runtime: nvidia` plus NVIDIA_* environment variables.
