# Jetson Ollama stack — installed to /opt/qtask-ollama/.env (created on first install).
# Full deploy: ./deploy/deploy-jetson-ollama.sh
# From dev machine: npm run publish:jetson
#
# Service VLAN IP only — do not use 0.0.0.0. Keeps Ollama off access interfaces.
JETSON_BIND_ADDRESS=192.168.13.14
#
# Publish does NOT update this file if it already exists. App-host OLLAMA_* vars are
# set on the QTask server (not here). Example app host .env:
#   OLLAMA_BASE_URL=http://192.168.13.14:11434
#   OLLAMA_MODEL=llama3.2:3b
#   OLLAMA_EMBEDDING_MODEL=nomic-embed-text
#   OLLAMA_DOCKER_STATS_URL=http://192.168.13.14:2375/v1.44
#   OLLAMA_DOCKER_CONTAINER=qtask-ollama
#   # DCGM_METRICS_URL=   # leave unset on Jetson
#
# Ollama in docker-compose.jetson.yml sets OLLAMA_KEEP_ALIVE=-1 and OLLAMA_MAX_LOADED_MODELS=2.
# deploy-jetson-ollama.sh warms chat + embedding models after start.
#
# Redeploy without re-pulling models: ./deploy/deploy-jetson-ollama.sh --skip-models
#
# Firewall: allow only the QTask app host to JETSON_BIND_ADDRESS:11434 and :2375.
# Do not port-forward those ports on your router.
